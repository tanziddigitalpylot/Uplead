# Server Configuration
PORT=4000
NODE_ENV=development


# JWT Configuration - MUST MATCH MONOLITH
JWT_SECRET=

JWT_EXPIRES_IN=24h
SESSION_DURATION_HOURS=24

# Logging
LOG_LEVEL=info


# MongoDB Configuration - Local Development (No Auth)
MONGODB_URI=


# Authentik SSO
AUTHENTIK_BASE_URL=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_REDIRECT_URI=http://localhost:4000/auth/authentik/callback
FRONTEND_URL=http://localhost:
NOTIFICATION_SERVICE_URL=http://localhost:4004
TELEGRAM_BOT_WEBHOOK_SECRET=your_secret_key_here
